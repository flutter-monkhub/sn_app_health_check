# Resend API key for sending alert and recovery emails
# Obtain from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Recipient email address for alert and recovery notifications
# Example: ops-team@yourcompany.com
ALERT_EMAIL_TO=recipient@example.com

# Sender email address (must be a verified domain in Resend)
# Example: alerts@yourverifieddomain.com
ALERT_EMAIL_FROM=alerts@yourverifieddomain.com

# Comma-separated list of API endpoint URLs to monitor (max 50)
# Each URL must start with http:// or https://
# If omitted, falls back to the default endpoint: https://apineuronv2.monkhub.com/user/login
# Example: https://api.example.com/health,https://api2.example.com/status
MONITOR_URLS=https://apineuronv2.monkhub.com/user/login

# Firebase project ID (used by Firebase Admin SDK if not auto-detected)
# Find this in your Firebase console under Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id
